# ─── Database (PostgreSQL / Supabase / Vercel) ───────────────────────────────
# Prisma needs a URL starting with postgresql:// or postgres://
#
# Option A — paste ONE pooled connection string (recommended):
POSTGRES_PRISMA_URL=
# or
POSTGRES_URL=

# Option B — explicit URL:
# DATABASE_URL="postgresql://..."

# Option C — discrete fields (Supabase / Vercel sometimes show these):
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=postgres
POSTGRES_PORT=5432
POSTGRES_SSL=
# POSTGRES_SSL=0   ← only if you must turn off SSL (rare)

# Direct connection (port 5432) — required for `migrate deploy` / `db push` on Supabase pooler
POSTGRES_URL_NON_POOLING=
# DIRECT_URL=postgresql://...   ← optional alias; same role as NON_POOLING

# Another name some templates use:
SUPABASE_DATABASE_URL=

# Remove SQLite when using Postgres:
# DATABASE_URL="file:./dev.db"   ← delete this line

# ─── NextAuth (required on Vercel: add NEXTAUTH_SECRET for Production + Preview) ─
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-string"
# AUTH_SECRET=...   ← optional alias; used if NEXTAUTH_SECRET is empty

# ─── Supabase client (optional; not used by Prisma) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
